# Required for production
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
DATABASE_URL_UNPOOLED=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://api.theracare.id
CORS_ORIGIN=https://admin.theracare.id,https://therapist.theracare.id,https://parent.theracare.id
PORTAL_RESET_PASSWORD=

# Recommended for Vercel + Neon serverless pooling
PG_POOL_MAX=3

# Optional admin Database Guard / Neon usage monitor
# Keep NEON_API_KEY only on the backend. Never expose it with VITE_ prefixes.
NEON_API_KEY=
NEON_PROJECT_ID=
NEON_BRANCH_ID=
NEON_DATA_TRANSFER_LIMIT_GB=5
NEON_USAGE_WARN_PERCENT=80
NEON_USAGE_CRITICAL_PERCENT=90
NEON_BACKUP_BRANCH_PREFIX=backup/theracare

# App links used by auth, email templates, and cross-origin allow-list
ADMIN_APP_URL=https://admin.theracare.id
THERAPIST_APP_URL=https://therapist.theracare.id
PARENT_APP_URL=https://parent.theracare.id

# Branding and profile uploads
BLOB_READ_WRITE_TOKEN=

# Email stays off until the sending domain is verified
EMAIL_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# Optional alternative storage providers
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
SUPABASE_STORAGE_PUBLIC_URL=
CDN_STORAGE_UPLOAD_URL=
CDN_STORAGE_PUBLIC_URL=
CDN_STORAGE_TOKEN=
CDN_STORAGE_METHOD=PUT
